  "faq": {
    "items": [
      { "id": "f01", "audience": "investor", "question": "Какой минимальный тикет LP?",                     "answer": "50 млн ₽ для LP. Обсуждаемо для anchor-LP.",                        "category": "terms" },
      { "id": "f02", "audience": "investor", "question": "Какой fund life?",                                 "answer": "7 лет с опцией продления на 2 года по согласованию LPAC.",            "category": "terms" },
      { "id": "f03", "audience": "investor", "question": "Как устроен waterfall?",                           "answer": "ROC → 8% preferred → 100% catch-up → 80/20 LP/GP.",                   "category": "terms" },
      { "id": "f04", "audience": "investor", "question": "Когда первые DPI?",                                "answer": "Плановый первый DPI — Q2 2029 (Year 4), после двух релизов.",         "category": "returns" },
      { "id": "f05", "audience": "investor", "question": "Как верифицированы цифры IRR?",                    "answer": "Финмодель v1.4.4, 348 тестов PASS, верификация П5 32/32 + М4 7/7.",     "category": "diligence" },
      { "id": "f06", "audience": "investor", "question": "Есть ли GP commitment?",                           "answer": "Да, 2% от committed capital, кэш.",                                   "category": "terms" },
      { "id": "f07", "audience": "investor", "question": "Что в случае недостижения hurdle?",                 "answer": "GP не получает carry. LP получает весь capital + доход до 8% и выше.","category": "terms" },
      { "id": "f08", "audience": "partner",  "question": "Возможно ли co-production?",                        "answer": "Да, мы открыты для co-production с российскими и международными партнёрами на ряде проектов.", "category": "partnerships" },
      { "id": "f09", "audience": "partner",  "question": "Доступны ли региональные рибейты?",                  "answer": "Работаем с региональными программами. Конкретный процент зависит от региона и типа spend.", "category": "operations" },
      { "id": "f10", "audience": "partner",  "question": "Как организован distribution?",                      "answer": "Внутренний Head of Distribution + партнёры по каждому каналу. Standard window: theatrical → OTT → TV.", "category": "distribution" },
      { "id": "f11", "audience": "talent",   "question": "Какого типа проекты вы делаете?",                    "answer": "Смешанный жанровый портфель: драма, триллер, исторический, семейный, авторский, сериалы.", "category": "production" },
