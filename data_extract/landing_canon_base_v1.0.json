  "risks": {
    "items": [
      { "id": "r01", "category": "market",       "title": "Падение theatrical-спроса",         "description": "Структурный сдвиг в сторону OTT снижает box office.", "severity": "medium",   "probability": "medium", "mitigation": "Гибкая распределение revenue между окнами, более агрессивный OTT-licensing." },
      { "id": "r02", "category": "production",   "title": "Срыв сроков production",            "description": "Погодные, логистические, cast-availability риски.",   "severity": "medium",   "probability": "high",   "mitigation": "Contingency 15% в бюджете, insurance, параллельные slots production." },
      { "id": "r03", "category": "production",   "title": "Overspend > 15%",                    "description": "Перерасход production budget.",                        "severity": "high",     "probability": "medium", "mitigation": "Gate-review на каждой стадии, stop-loss по превышению порога." },
      { "id": "r04", "category": "financial",    "title": "Delayed LP capital calls",           "description": "Задержки call-ов со стороны LP.",                     "severity": "medium",   "probability": "low",    "mitigation": "Bridge-facility с банком-партнёром, диверсификация LP-базы." },
      { "id": "r05", "category": "regulatory",   "title": "Изменения в гос.регулировании",      "description": "Корректировка правил контент-регулирования.",         "severity": "high",     "probability": "medium", "mitigation": "Legal advisor in-house, сценарии с early-warning." },
      { "id": "r06", "category": "distribution", "title": "Потеря OTT-канала",                  "description": "Изменение стратегии ключевого OTT-партнёра.",         "severity": "medium",   "probability": "medium", "mitigation": "Диверсификация OTT (минимум 3 платформы)." },
      { "id": "r07", "category": "operational",  "title": "Key-person risk",                    "description": "Уход ключевого члена команды.",                       "severity": "high",     "probability": "low",    "mitigation": "Key-person clause в LP agreement, bench depth." },
      { "id": "r08", "category": "talent",       "title": "Дефицит режиссёров/актёров",         "description": "Конкуренция за top talent с другими студиями.",       "severity": "medium",   "probability": "medium", "mitigation": "Long-term multi-project deals, retainer-контракты." },
      { "id": "r09", "category": "tech",         "title": "Технологическая disruption (AI)",    "description": "AI-контент меняет экономику production.",              "severity": "medium",   "probability": "medium", "mitigation": "Внедрение AI-инструментов в pre-viz, VFX, dubbing." },
      { "id": "r10", "category": "market",       "title": "Валютные риски",                     "description": "Импортное оборудование, международные расчёты.",     "severity": "medium",   "probability": "medium", "mitigation": "Forward-контракты на валюту, локализация supply chain." },
      { "id": "r11", "category": "financial",    "title": "Недостижение hurdle rate",           "description": "IRR ниже 8% → нулевой carry для GP.",                  "severity": "medium",   "probability": "low",    "mitigation": "Дисциплина гейтов, гибкое перераспределение budget между проектами." },
      { "id": "r12", "category": "distribution", "title": "Пиратство и копирайт",                "description": "Неконтролируемое распространение контента.",          "severity": "low",      "probability": "high",   "mitigation": "Anti-piracy сервисы, DMCA-процедуры, watermarking." }
    ]
  },

