{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "signature": "shadows_of_sunset_v1",
  "version": "1.0.0",
  "mode": "dark",
  "source": "landing_canon_extended_v1.0.json §palette + §typography",
  "palette": {
    "bg":          "#0A0A0F",
    "bg_elevated": "#141420",
    "surface":     "#1E1E2E",
    "text":        "#F5F1E8",
    "text_muted":  "#8B8680",
    "primary":     "#D4A04C",
    "accent":      "#C85A2E",
    "bull":        "#2E7D32",
    "bear":        "#C62828",
    "neutral":     "#757575",
    "border":      "#2A2A3E"
  },
  "shadows": {
    "sm": "0 2px 4px rgba(0,0,0,0.4)",
    "md": "0 4px 12px rgba(0,0,0,0.5)",
    "lg": "0 12px 32px rgba(0,0,0,0.6)"
  },
  "radii": {
    "sm": "4px",
    "md": "8px",
    "lg": "16px"
  },
  "typography": {
    "families": {
      "display": {
        "name":     "Cormorant Garamond",
        "fallback": "Georgia, 'Times New Roman', serif",
        "source":   "Google Fonts"
      },
      "body": {
        "name":     "Inter",
        "fallback": "-apple-system, system-ui, sans-serif",
        "source":   "Google Fonts"
      }
    },
    "scale": {
      "h1":      "clamp(2.5rem, 5vw, 4.5rem)",
      "h2":      "clamp(2rem, 4vw, 3.25rem)",
      "h3":      "clamp(1.5rem, 3vw, 2.25rem)",
      "h4":      "1.25rem",
      "body":    "1rem",
      "caption": "0.875rem"
    },
    "line_heights": {
      "tight":   1.1,
      "normal":  1.5,
      "relaxed": 1.75
    },
    "weights": {
      "regular": 400,
      "medium":  500,
      "bold":    700
    }
  },
  "contrast_pairs": {
    "_doc": "Проверяется в tokens.test.js (WCAG 2.1: AA normal=4.5, AA large=3.0, AAA normal=7.0). Поле min_ratio — гарантированный порог, реальное значение пересчитывается тестом.",
    "text_on_bg":          { "fg": "text",       "bg": "bg",          "min_ratio": 7.0, "wcag": "AAA" },
    "text_on_bg_elevated": { "fg": "text",       "bg": "bg_elevated", "min_ratio": 7.0, "wcag": "AAA" },
    "text_on_surface":     { "fg": "text",       "bg": "surface",     "min_ratio": 7.0, "wcag": "AAA" },
    "text_muted_on_bg":    { "fg": "text_muted", "bg": "bg",          "min_ratio": 4.5, "wcag": "AA"  },
    "primary_on_bg":       { "fg": "primary",    "bg": "bg",          "min_ratio": 7.0, "wcag": "AAA" },
    "accent_on_bg":        { "fg": "accent",     "bg": "bg",          "min_ratio": 4.5, "wcag": "AA"  },
    "bull_on_bg":          { "fg": "bull",       "bg": "bg",          "min_ratio": 3.0, "wcag": "AA-large-only" },
    "bear_on_bg":          { "fg": "bear",       "bg": "bg",          "min_ratio": 3.0, "wcag": "AA-large-only" }
  }
}
