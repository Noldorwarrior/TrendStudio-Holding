    {
      "id": "INV-01",
      "name": "Canon parity",
      "description": "Все значения в HTML (числа, тексты, id) происходят из canon JSON. Запрещены inline-константы, дублирующие canon.",
      "check_tool": "invariants_check.py::check_canon_parity",
      "severity": "blocker"
    },
    {
      "id": "INV-02",
      "name": "i18n symmetry",
      "description": "landing_ru.json и landing_en.json имеют идентичный набор ключей (0 asymmetry).",
      "check_tool": "scripts/i18n_check.py",
      "severity": "blocker"
    },
    {
      "id": "INV-03",
      "name": "Numerical parity",
      "description": "Симуляторы (sim01–sim13) возвращают значения в пределах tolerance от canon-референса (см. DETAIL §2.6).",
      "check_tool": "invariants_check.py::check_numerical_parity",
      "severity": "blocker"
    },
    {
      "id": "INV-04",
      "name": "a11y baseline",
      "description": "WCAG 2.1 AA: focus-visible, reduced-motion support, keyboard nav, aria-labelledby, fallback aria_table для каждой viz.",
      "check_tool": "invariants_check.py::check_a11y + axe-core",
      "severity": "blocker"
    },
    {
      "id": "INV-05",
      "name": "Budget ceiling",
      "description": "Итоговый HTML ≤ 1 200 KB soft (warning) / ≤ 2 000 KB hard (fail).",
      "check_tool": "invariants_check.py::check_budget",
      "severity": "blocker"
    },
    {
      "id": "INV-06",
      "name": "Security baseline",
      "description": "Нет eval / new Function / localStorage / inline event handlers / external CDN без integrity / img без alt.ru+alt.en.",
      "check_tool": "invariants_check.py::check_security",
      "severity": "blocker"
    },
    {
      "id": "INV-07",
      "name": "Deterministic MC",
      "description": "Все Monte Carlo симуляции используют фиксированный seed из спецификации DETAIL §4 (воспроизводимые результаты между рендерами).",
      "check_tool": "invariants_check.py::check_mc_determinism",
      "severity": "blocker"
    }
  ],
  "hard_constraints_checklist": [
    "no_eval",
    "no_new_function",
    "no_localstorage",
    "no_sessionstorage_except_scenario",
    "no_inline_event_handlers",
